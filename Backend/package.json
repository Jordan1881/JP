{
  "name": "@jp/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --config ../../eslint.config.mjs --max-warnings 0",
    "test": "echo \"Backend module tests live in @jp/tests\"",
    "db:migrate": "tsc -p tsconfig.json && node dist/db/migrate-cli.js"
  },
  "dependencies": {
    "@jp/shared-types": "workspace:*",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/aws-lambda": "^8.10.159",
    "@types/node": "^22.19.1",
    "@types/pg": "^8.15.6",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
