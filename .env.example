# JP Job Player — environment variables
# Copy to .env.local at the **repo root** (local dev loads this into Next.js API routes)

# Frontend (Next.js / Amplify)
# API Gateway base URL (CDK "ApiUrl" output). When set, Next.js API routes
# proxy to the deployed ApiHandler Lambda (ADR-0004); when empty, local dev
# uses in-memory stores.
JP_API_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_REGION=

# Backend (Lambda)
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=jp
DATABASE_USER=
DATABASE_PASSWORD=

# CDK deploy
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=us-east-1

# Feature 2 — Claude API (issue #7, stored in Secrets Manager in prod)
ANTHROPIC_API_KEY=
