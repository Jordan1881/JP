{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@frontend/*": ["../Frontend/*"],
      "@backend/*": ["../Backend/src/*"]
    }
  },
  "include": ["**/*.ts"]
}
